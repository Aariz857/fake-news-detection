# ============================================
# Fake News Detection — Environment Variables
# Copy to .env and fill in your keys
# ============================================

# App Settings
APP_NAME=Fake News Detector API
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]

# Mock Mode (set to False when API keys are configured)
MOCK_MODE=True

# API Keys (leave empty for mock mode)
NEWSAPI_KEY=
GOOGLE_API_KEY=
GOOGLE_CX_ID=
OPENAI_API_KEY=

# Model Settings
BERT_MODEL_NAME=jy46604790/Fake-News-Bert-Detect
USE_GPU=False

# Tesseract OCR (auto-detected on Windows, set path if needed)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
